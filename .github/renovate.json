{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "baseBranchPatterns": [
    "develop"
  ],
  "schedule": [
    "before 5am on saturday",
    "before 5am on tuesday"
  ],
  "packageRules": [
    {
      "groupName": "Kotlin & KSP",
      "matchPackageNames": [
        "/^org.jetbrains.kotlin/",
        "/^com.google.devtools.ksp/"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    }
  ]
}
